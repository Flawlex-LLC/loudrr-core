# Backend Environment Configuration
# Copy this file to .env and fill in your values

# === Django Core ===
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# === Database ===
# Direct PostgreSQL connection (development):
# DATABASE_URL=postgres://user:password@localhost:5432/loudrr

# With PgBouncer (recommended for production with 100+ users):
# PgBouncer port is 6432, PostgreSQL is 5432
# In Coolify: point to pgbouncer service name instead of postgres
DATABASE_URL=postgres://user:password@pgbouncer:6432/loudrr

# === PgBouncer Configuration ===
# These are used by the PgBouncer container in Coolify
# PGBOUNCER_DATABASE=loudrr
# PGBOUNCER_HOST=your-postgres-host
# PGBOUNCER_PORT=5432
# PGBOUNCER_USER=your-db-user
# PGBOUNCER_PASSWORD=your-db-password
# PGBOUNCER_POOL_MODE=transaction
# PGBOUNCER_MAX_CLIENT_CONN=200
# PGBOUNCER_DEFAULT_POOL_SIZE=25

# === Redis & Celery ===
REDIS_URL=redis://localhost:6379/0

# === CORS Configuration ===
# Production: Set to False and specify exact origins
CORS_ALLOW_ALL_ORIGINS=True
# Production example:
# CORS_ALLOWED_ORIGINS=https://loudrr.com,https://www.loudrr.com,https://app.loudrr.com

# === URLs ===
# Base site URL (landing at /, mini app at /app, card APIs at /api/cards/*)
SITE_URL=http://localhost:3000
# MINIAPP_URL and LANDING_URL default to SITE_URL+/app and SITE_URL respectively.
# Only override if serving from a different domain than the base site.
# MINIAPP_URL=http://localhost:3000/app
# LANDING_URL=http://localhost:3000

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_BOT_USERNAME=Loudrrbot
# For production webhook mode. If both set, bot listens at /api/telegram/webhook/.
# If unset, run `python manage.py run_telegram_bot` (polling mode) for local dev.
# TELEGRAM_WEBHOOK_URL=https://api.loudrr.com/api/telegram/webhook/
# TELEGRAM_WEBHOOK_SECRET=generate-random-32-char-string

# === X (Twitter) OAuth 2.0 ===
# Get these from https://developer.twitter.com -> App -> User authentication settings
# Required scopes: users.read tweet.read
# Callback URL must match what's set in the Developer Portal exactly.
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
# Defaults to {SITE_URL}/api/auth/x/callback/ — only override if backend lives on a different host.
# X_OAUTH_CALLBACK_URL=https://api.loudrr.com/api/auth/x/callback/

# === Admin ===
# Comma-separated list of Telegram user IDs with admin access
ADMIN_TELEGRAM_IDS=123456789

# === Email Configuration ===
# For production, use SMTP services like AWS SES, SendGrid, Mailgun
# In development, emails are printed to console by default
#
# Example for SendGrid:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=Loudrr <noreply@loudrr.com>
#
# Example for AWS SES:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-ses-smtp-username
# EMAIL_HOST_PASSWORD=your-ses-smtp-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=Loudrr <noreply@loudrr.com>

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Loudrr <noreply@loudrr.com>

# === External APIs ===
# Twitter API for verification
TWITTER_API_KEY=your-twitter-api-key
# TweetScout API for user scoring
TWEETSCOUT_API_KEY=your-tweetscout-api-key
