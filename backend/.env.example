# Copy to .env and fill in. .env is gitignored; never commit real secrets.

# Core
DEBUG=true
ITEMS_PER_PAGE=50
DATABASE_URL=postgresql+asyncpg://loudrr:loudrr@localhost:5432/loudrr

# Redis / task queue (Ch16)
REDIS_URL=redis://localhost:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# External services (Ch10 TweetScout, Ch13 Twitter)
TWEETSCOUT_API_KEY=
TWITTER_API_KEY=

# X OAuth 2.0 (Ch11)
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
X_OAUTH_CALLBACK_URL=

# URLs / misc
SITE_URL=
LANDING_URL=
ENCRYPTION_KEY=
CORS_ALLOWED_ORIGINS=

# Task queue (Ch16) — set true in prod with Redis + a running arq worker
USE_TASK_QUEUE=false

# Admin panel (Ch17) — /admin login; blank password disables admin login
SECRET_KEY=dev-insecure-secret-change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
