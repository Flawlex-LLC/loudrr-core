# =============================================================================
# Loudrr Environment Variables
# =============================================================================
# Copy to .env and configure for your environment

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DB_NAME=loudrr
DB_USER=loudrr
DB_PASSWORD=your-secure-password-here
# For docker-compose, use: postgresql://loudrr:password@db:5432/loudrr
# For external DB, use full URL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# =============================================================================
# DJANGO
# =============================================================================
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=api.loudrr.com,localhost,127.0.0.1

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# CORS
# =============================================================================
CORS_ALLOWED_ORIGINS=https://app.loudrr.com,https://loudrr.com,http://localhost:3000

# =============================================================================
# TELEGRAM BOT
# =============================================================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
MINIAPP_URL=https://app.loudrr.com

# =============================================================================
# EXTERNAL APIS
# =============================================================================
# TweetScout API (for user scoring)
TWEETSCOUT_API_KEY=your-tweetscout-api-key

# Twitter API via twitterapi.io (for verification)
TWITTER_API_KEY=your-twitter-api-key

# =============================================================================
# FRONTEND (Next.js)
# =============================================================================
NEXT_PUBLIC_API_URL=https://api.loudrr.com

# =============================================================================
# SECURITY
# =============================================================================
# Encryption key for redirect URLs (must be 32 bytes)
ENCRYPTION_KEY=your-32-byte-encryption-key-here
